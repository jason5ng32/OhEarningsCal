# Copy this to .env for local development.
# In GitHub Actions, set the same names under repo Settings → Variables.

# Whether to generate selected.ics (union of all indices + custom).
SHOULD_GEN_SELECTED=true

# Whether to generate all.ics (every ticker the API returned).
SHOULD_GEN_ALL=true

# Comma-separated tickers driving customstock.ics. Leave empty to skip.
# Example: CUSTOM_STOCKS=PDD,BABA,TCEHY
CUSTOM_STOCKS=

# Local dev server port (server.js only).
PORT=18302
